              "regex": "\\bif\\s+.*,\\s+then\\s+(?:perhaps|maybe)",
              "note": "Nested conditional clause"
            },
            {
              "regex": "\\bI\\s+(?:calculate|determine|process|analyze|optimize)\\b",
              "note": "Self-referential processing"
            },
            { "regex": "\\b\\d{1,3}(?:\\.\\d+)?%", "note": "Percentages / probabilistic hedging" },
            { "regex": "\\b(?:query|recursive|iterate|loop)\\b", "note": "Algorithm vocabulary" },
            { "regex": "\\b\\d{2}:\\d{2}(?::\\d{2})?\\b", "note": "Precise clock timestamp" }
          ],
          "last-human": [
