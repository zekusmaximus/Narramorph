    "portedAt": "2026-07-16",
    "note": "Machine rules ported from the manuscript repository's stdlib validators and bible at the pinned commit (the accepted literary release's sourceCommit). The manuscript remains the rule source of record; a future literary release that exports rule data supersedes this port. Terminology and chronology rules additionally derive from contradiction-register findings CTR-005/CTR-006, whose canonical citations are recorded in the register.",
    "sourceFiles": [
      "scripts/philosophy_checker.py (SHACKLE_PATTERNS, FORBIDDEN_MOVES)",
      "scripts/voice_validator.py (VOICE_CORE, CONTAMINATION_MARKERS)",
      "bible/philosophy-constraints.md",
      "bible/voices/quick-reference.md",
      "bible/worldbuilding/near-future.md",
      "bible/worldbuilding/catastrophe-timeline.md",
      "bible/name-index.md",
      "bible/rhyme-registry.md (designed-repetition allowlist)"
    ]
  },
  "shackles": {
    "identity": {
      "description": "Collapsing difference into sameness between the three protagonists",
      "patterns": [
        {
          "regex": "\\b(?:he|she|they|I|we)\\s+(?:is|are|was|were)\\s+(?:the\\s+)?same\\b",
          "note": "Explicit sameness claim"
        },
        {
          "regex": "\\brecognized?\\s+(?:him|her|them|my|our)sel(?:f|ves)\\s+in\\b",
          "note": "Self-recognition IN another (vs. through)"
        },
        {
          "regex": "\\b(?:really|truly|actually)\\s+(?:just|only)\\s+one\\s+(?:person|being|consciousness)\\b",
          "note": "Unity assertion"
        },
        {
          "regex": "\\bthe\\s+same\\s+(?:person|soul|consciousness|being)\\b",
          "note": "Same-person claim"
        },
        {
          "regex": "\\bidentical\\s+(?:to|with)\\s+(?:him|her|them)self\\b",
          "note": "Identity assertion"
        },
        {
          "regex": "\\b(?:single|one)\\s+consciousness\\s+distributed\\s+across\\s+(?:temporal|time|examination|centuries|eras)\\b",
          "note": "Cross-era distributed single-consciousness claim (CTR-007); the Algorithm's own internal streams are legitimate self-reference and excluded"
        },
        {
          "regex": "\\bwe(?:'re|\\s+are)\\s+not\\s+three\\s+separate\\b",
          "note": "Three-as-one denial (CTR-007)"
        }
      ]
    },
    "opposition": {
      "description": "Human/AI or flesh/digital binaries",
      "patterns": [
        {
          "regex": "\\b(?:human|organic)\\s+(?:vs\\.?|versus|against|or)\\s+(?:machine|AI|digital|artificial)\\b",
          "note": "Binary opposition"
        },
        {
          "regex": "\\b(?:real|authentic|true)\\s+(?:vs\\.?|versus|against|or)\\s+(?:artificial|fake|simulated)\\b",
          "note": "Authenticity binary"
        },
        {
          "regex": "\\b(?:opposites?|contrary|contraries)\\s+(?:drawn|attracted|pulled)\\b",
          "note": "Opposites-attract trope"
        }
      ]
    },
    "analogy": {
      "description": "Reducing one thread to 'like' another",
      "patterns": [
        {
          "regex": "\\b(?:functioned?|worked?|operated?)\\s+(?:like|as)\\s+(?:a\\s+)?(?:human|mind|brain)\\b",
          "note": "Functional analogy"
        },
        {
          "regex": "\\blike\\s+(?:a\\s+)?(?:different\\s+)?(?:version|copy|instance)\\s+of\\b",
          "note": "Copy analogy"
        },
        {
          "regex": "\\bdigital\\s+(?:equivalent|analogue|version)\\s+of\\b",
          "note": "Equivalence claim"
        },
        {
          "regex": "\\bjust\\s+like\\s+(?:a|the)\\s+(?:human|person|mind)\\b",
          "note": "Humanizing analogy"
        }
      ]
    },
    "resemblance": {
      "description": "Similarity as basis for connection",
      "patterns": [
        {
          "regex": "\\bthis\\s+remind(?:s|ed)\\s+(?:me|him|her)\\s+of\\b",
          "note": "Reminder-based recognition"
        },
        {
          "regex": "\\bhad\\s+seen\\s+(?:this|that|the)\\s+(?:face|shape|form)\\s+before\\b",
          "note": "Visual similarity"
        },
        {
          "regex": "\\bfamiliar(?:ity)?\\s+(?:of|with|in)\\s+the\\s+(?:way|manner)\\b",
          "note": "Familiarity-based"
        },
        {
          "regex": "\\blooks?\\s+like\\s+(?:a\\s+)?(?:younger|older)\\s+(?:version|self)\\b",
          "note": "Physical resemblance"
        }
      ]
    }
  },
  "forbiddenMoves": {
    "transmission": {
      "description": "Protocols 'sent' rather than structurally present",
      "patterns": [
        {
          "regex": "\\b(?:sent?|transmitted?|broadcast)\\s+(?:the\\s+)?protocols?\\s+(?:back|backward)\\b",
          "note": "Transmission metaphor"
        },
        {
          "regex": "\\bmessage\\s+from\\s+(?:the\\s+)?future\\b",
          "note": "Message-from-future framing"
        },
        {
          "regex": "\\b(?:he|she|it)\\s+was\\s+sending\\s+(?:the\\s+)?protocols?\\b",
          "note": "Active sending"
        }
      ]
    },
    "goal-planning": {
      "description": "The Algorithm as planning agent rather than emergent pattern",
      "patterns": [
        {
          "regex": "\\bthe\\s+Algorithm\\s+(?:planned|designed|intended)\\b",
          "note": "Planning language"
        },
        {
          "regex": "\\bpurpose(?:ly|fully)?\\s+(?:created|built|designed)\\b",
          "note": "Purposeful creation"
        },
        {
          "regex": "\\bIn\\s+order\\s+to\\s+(?:ensure|guarantee|make\\s+sure)\\b",
          "note": "Goal-directed framing"
        }
      ]
    },
    "transcendence": {
      "description": "Escape rather than transformation",
      "patterns": [
        {
          "regex": "\\bfree\\s+from\\s+(?:the\\s+)?(?:constraints?|limitations?|bonds?)\\b",
          "note": "Freedom-from language"
        },
        {
          "regex": "\\bescaped?\\s+(?:from\\s+)?(?:time|mortality|death|flesh|body)\\b",
          "note": "Escape narrative"
        },
        {
          "regex": "\\btranscend(?:ed|ing|s)?\\s+(?:the\\s+)?(?:human|physical|material)\\b",
          "note": "Transcendence claim"
        },
        { "regex": "\\bbecame?\\s+(?:pure|perfect|infinite)\\b", "note": "Perfection language" }
      ]
    }
  },
  "terminology": {
    "description": "Renamed canonical entities and invented era/institution names are errors (ADR 0002: controlled terminology is alignment-mandatory). Canonical citations: contradiction register CTR-005.",
    "forbiddenTerms": [
      {
        "id": "upload-era",
        "regex": "\\bUpload\\s+Era\\b",
        "canonical": "Integration Era",
        "note": "Invented era name; the canonical named concept is the Integration Era (bible/name-index.md)"
      },
      {
        "id": "great-aggregation",
        "regex": "\\bGreat\\s+Aggregation\\b",
        "canonical": "no canonical equivalent",
        "note": "Invented consolidation event absent from the canonical catastrophe timeline"
      },
      {
        "id": "great-archive",
        "regex": "\\bGreat\\s+Archive\\b",
        "canonical": "the Archive / the Deep Architecture",
        "note": "Invented institution; canon names the near-future database the Deep Architecture and the later-era system the Archive"
      },
      {
        "id": "consciousness-archival-facility",
        "regex": "\\bConsciousness\\s+Archival\\s+Facility\\b",
        "canonical": "no canonical equivalent",
        "note": "Invented institution absent from the name index"
      }
    ]
  },
  "chronology": {
    "description": "Canon keeps era dating relative (decades / centuries / millennia from present); absolute calendar years are chronology conflicts (errors). Canonical citations: contradiction register CTR-006.",
    "absoluteDatePatterns": [
      {
        "regex": "\\b(?:19[0-9]{2}|2[0-3][0-9]{2})\\b",
        "note": "Absolute calendar year (1900-2399)"
      }
    ]
  },
  "voices": {
    "description": "Signature and contamination rules per canonical voice, keyed by release voiceId. Contamination is designed (licensed) in dissolution-era content: layers 3 and 4 and any multi-voice family. Signature/contamination findings are stylistic-drift warnings per the roadmap unless the owner promotes a rule.",
    "profiles": {
      "archaeologist": {
        "signaturePatterns": [
          {
            "regex": "\\bI\\s+(?:find|see|hear|feel|touch|grab|take|put|hold|work|look|watch)\\b",
            "note": "Active tactile first person"
          },
          {
            "regex": "\\b(?:drive|server|interface|terminal|screen|hardware)\\b",
            "note": "Near-future hardware texture"
          },
          {
            "regex": "\\b(?:cold|weight|pressure|texture|smooth|rough|heavy)\\b",
            "note": "Physical sensation vocabulary"
          },
