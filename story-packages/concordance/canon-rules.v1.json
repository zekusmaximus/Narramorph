              "note": "Archaeologist's world specifics"
            }
          ],
          "last-human": [
            { "regex": "(?:^|\\.\\s+)[A-Z][a-z]+\\.\\s*$", "note": "Sentence fragment ending" },
            { "regex": "\\b(?:ruins?|decay|crumble|erode)\\b", "note": "Elegiac vocabulary" },
            {
              "regex": "\\b(?:last|only|final)\\s+(?:human|person|one)\\b",
              "note": "Last Human identity"
            }
          ]
        }
      },
      "last-human": {
        "signaturePatterns": [
          { "regex": "\\b(?:was|were|had been|once|used to)\\b", "note": "Past-inflected present" },
          {
            "regex": "\\b(?:ruins?|decay|crumble|empty|hollow|silence|alone)\\b",
            "note": "Absence and ruin vocabulary"
          },
          { "regex": "\\b(?:walk|journey|path|distance|horizon)\\b", "note": "Embodied traversal" },
          { "regex": "(?:^|\\.\\s+)[A-Z][a-z]+\\.", "note": "Sentence fragments" }
        ],
        "contamination": {
          "archaeologist": [
            {
              "regex": "\\b(?:client|contract|fee|payment|cost|afford)\\b",
              "note": "Economic concerns"
            },
            {
              "regex": "\\b(?:interface|terminal|server|drive)\\b",
              "note": "Near-future technology"
            },
            {
