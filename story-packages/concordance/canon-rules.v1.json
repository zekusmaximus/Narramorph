        "contamination": {
          "archaeologist": [
            {
              "regex": "\\bI\\s+(?:grab|touch|feel|hold)\\s+(?:the|a|my)\\b",
              "note": "Physical tactile action"
            },
            {
              "regex": "\\b(?:cold|warm|weight|pressure)\\s+(?:of|in|on|against)\\b",
              "note": "Physical sensation"
            },
            {
