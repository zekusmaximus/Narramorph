              "regex": "(?:^|\\.\\s+)[A-Z][a-z]+\\.\\s+[A-Z][a-z]+\\.",
              "note": "Consecutive fragments"
            },
            {
              "regex": "\\b(?:once|had been|was a)\\s+(?:time|city|world)\\b",
              "note": "Elegiac past-inflection"
            },
            {
              "regex": "\\b(?:silence|emptiness|hollow|alone)\\s+(?:of|in|that)\\b",
              "note": "Absence vocabulary"
            }
          ]
        }
      },
      "algorithm": {
        "signaturePatterns": [
          {
            "regex": "\\bI\\s+(?:process|analyze|verify|calculate|model|query)\\b",
            "note": "Processing first person"
          },
          {
            "regex": "\\b(?:if|would|could|might|perhaps|should)\\b.*\\b(?:then|therefore)\\b",
            "note": "Conditional reasoning"
          },
          {
