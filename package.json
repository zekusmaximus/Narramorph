{
  "name": "narramorph-fiction",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Interactive narrative platform for creating node-based story experiences",
  "author": "zekusmaximus",
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "dev:test": "cross-env PLAYWRIGHT_TEST=1 vite --host 127.0.0.1 --port 4174 --strictPort",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:run": "vitest run",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "bundle:check": "node scripts/check-bundle-budgets.mjs",
    "profile:l3": "vite-node tools/performance/profile-l3.ts",
    "prepare": "husky",
    "lint": "cross-env ESLINT_USE_FLAT_CONFIG=false eslint . --cache",
    "lint:fix": "cross-env ESLINT_USE_FLAT_CONFIG=false eslint . --cache --fix && npm run format",
    "lint:ci": "cross-env ESLINT_USE_FLAT_CONFIG=false eslint . --max-warnings=120",
    "format": "prettier . --write --ignore-unknown",
    "format:check": "prettier . --check --ignore-unknown",
    "type-check": "tsc --noEmit",
    "validate": "npm run type-check && npm run lint:ci && npm test",
    "content:install": "npm ci --prefix tools/conversion",
    "content:convert": "npm --prefix tools/conversion run convert --",
    "content:convert:l1": "npm --prefix tools/conversion run convert:l1 --",
    "content:convert:l2": "npm --prefix tools/conversion run convert:l2 --",
    "content:convert:l3": "npm --prefix tools/conversion run convert:l3 --",
    "content:convert:l4": "npm --prefix tools/conversion run convert:l4 --",
    "content:convert:all": "npm --prefix tools/conversion run convert:all --",
    "content:convert:watch": "npm --prefix tools/conversion run convert:watch --",
    "content:validate": "npm --prefix tools/conversion run validate --",
    "content:validate:runtime": "vitest run src/utils/validateRuntimeContent.test.ts",
    "content:aggregate": "npm --prefix tools/conversion run aggregate --",
    "content:matrix": "npm --prefix tools/conversion run matrix --",
    "content:diff": "npm --prefix tools/conversion run diff --",
    "content:rollback": "npm --prefix tools/conversion run rollback --"
  },
  "dependencies": {
    "@react-spring/three": "^9.7.3",
    "@react-three/drei": "^9.92.0",
    "@react-three/fiber": "^8.15.0",
    "@xyflow/react": "^12.0.0",
    "clsx": "^2.1.0",
    "framer-motion": "^11.0.0",
    "immer": "^10.0.3",
    "lucide-react": "^0.553.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-error-boundary": "^6.0.0",
    "tailwindcss": "^3.4.0",
    "three": "^0.159.0",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@testing-library/jest-dom": "^6.1.5",
    "@testing-library/react": "^14.1.0",
    "@testing-library/user-event": "^14.5.1",
    "@types/node": "^24.10.1",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "8.64.0",
    "@typescript-eslint/parser": "8.64.0",
    "@vitejs/plugin-react": "5.2.0",
    "@vitest/coverage-v8": "3.2.7",
    "@vitest/ui": "3.2.7",
    "autoprefixer": "^10.4.16",
    "cross-env": "^7.0.3",
    "eslint": "^8.55.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-prettier": "^5.1.3",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "eslint-plugin-unused-imports": "4.4.1",
    "husky": "^9.1.7",
    "jsdom": "^23.0.0",
    "lint-staged": "^15.2.0",
    "postcss": "8.5.19",
    "prettier": "^3.1.1",
    "typescript": "^5.3.3",
    "vite": "7.3.6",
    "vitest": "3.2.7"
  },
  "engines": {
    "node": ">=22.0.0 <25.0.0",
    "npm": ">=10.0.0 <12.0.0"
  },
  "browserslist": {
    "production": [
      ">0.5%",
      "last 2 versions",
      "Firefox ESR",
      "not dead"
    ],
    "development": [
      "last 1 Chrome version"
    ]
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --cache --fix",
      "prettier --write"
    ],
    "*.{md,json,css,scss}": [
      "prettier --write"
    ]
  }
}
