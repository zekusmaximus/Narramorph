{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://narramorph.example/schemas/story-package/v1/condition-expression.schema.json",
  "title": "Narramorph Journey Condition Expression v1.1",
  "oneOf": [
    {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "passageIds"],
      "properties": {
        "kind": { "enum": ["historyStartsWith", "historyEndsWith", "orderSeen"] },
        "passageIds": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "beforePassageId", "afterPassageId"],
      "properties": {
        "kind": { "const": "visitedImmediatelyAfter" },
        "beforePassageId": { "type": "string", "minLength": 1 },
        "afterPassageId": { "type": "string", "minLength": 1 }
      }
    },
    {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "passageId", "steps"],
      "properties": {
        "kind": { "const": "withinSteps" },
        "passageId": { "type": "string", "minLength": 1 },
        "steps": { "type": "integer", "minimum": 0 }
      }
    },
    {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "passageId", "comparison", "value"],
      "properties": {
        "kind": { "const": "visitCount" },
        "passageId": { "type": "string", "minLength": 1 },
        "comparison": { "enum": ["eq", "ne", "gt", "gte", "lt", "lte"] },
        "value": { "type": "integer", "minimum": 0 }
      }
    },
    {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "passageIds", "comparison", "value"],
      "properties": {
        "kind": { "const": "visitedCountAcross" },
        "passageIds": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        },
        "comparison": { "enum": ["eq", "ne", "gt", "gte", "lt", "lte"] },
        "value": { "type": "integer", "minimum": 0 }
      }
    },
    {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "conditions"],
      "properties": {
        "kind": { "enum": ["all", "any"] },
        "conditions": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "condition-expression.schema.json" }
        }
      }
    },
    {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "condition"],
      "properties": {
        "kind": { "const": "not" },
        "condition": { "$ref": "condition-expression.schema.json" }
      }
    }
  ]
}
