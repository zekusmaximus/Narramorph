{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://narramorph.example/schemas/story-package/v1/manifest.schema.json",
  "title": "Narramorph Story Package Manifest v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "contract",
    "schemaVersion",
    "storyId",
    "storyVersion",
    "title",
    "sourceManuscriptCommit",
    "editorialReleaseId",
    "licenses",
    "generatedAt",
    "generation",
    "contentHash",
    "supportedAppRange",
    "layerCounts",
    "passageIds",
    "provenance",
    "catalog"
  ],
  "properties": {
    "contract": { "const": "org.narramorph.story-package" },
    "schemaVersion": { "type": "string", "pattern": "^1\\.[0-9]+\\.[0-9]+$" },
    "storyId": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
    "storyVersion": {
      "type": "string",
      "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)(?:-[0-9A-Za-z.-]+)?$"
    },
    "title": { "type": "string", "minLength": 1 },
    "sourceManuscriptCommit": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
    "editorialReleaseId": { "type": "string", "minLength": 1 },
    "licenses": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["spdx", "scope", "attribution"],
        "properties": {
          "spdx": { "type": "string", "minLength": 1 },
          "scope": { "type": "string", "minLength": 1 },
          "attribution": { "type": "string", "minLength": 1 }
        }
      }
    },
    "generatedAt": { "type": "string", "format": "date-time" },
    "generation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["generator", "generatorVersion", "sourceDateEpoch", "canonicalization"],
      "properties": {
        "generator": { "type": "string", "minLength": 1 },
        "generatorVersion": { "type": "string", "minLength": 1 },
        "sourceDateEpoch": { "type": "string", "format": "date-time" },
        "canonicalization": { "const": "narramorph-canonical-json-v1" }
      }
    },
    "contentHash": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "supportedAppRange": { "type": "string", "pattern": "^>=\\S+ <\\S+$" },
    "layerCounts": {
      "type": "object",
      "propertyNames": { "pattern": "^[0-9]+$" },
      "additionalProperties": { "type": "integer", "minimum": 0 }
    },
    "passageIds": {
      "type": "array",
      "uniqueItems": true,
      "items": { "type": "string", "pattern": "^spv1_psg_[0-9a-f]{24}$" }
    },
    "provenance": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["relation", "repository", "commit", "releaseId"],
        "properties": {
          "relation": { "type": "string", "minLength": 1 },
          "repository": { "type": "string", "minLength": 1 },
          "commit": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
          "releaseId": { "type": "string", "minLength": 1 },
          "path": { "type": "string", "minLength": 1 }
        }
      }
    },
    "catalog": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "sha256"],
      "properties": {
        "path": { "const": "catalog.json" },
        "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
      }
    }
  }
}
